      "expectedErrorMessage": "Product with id '-1' not found"
    },
    {
      "scenario": "GET_PRODUCT_BY_ID_NOT_FOUND",
      "productId": 0,
      "expectedStatusCode": 404,
      "expectedErrorMessage": "Product with id '0' not found"
    }
  ],

  "searchProductsTestData": [

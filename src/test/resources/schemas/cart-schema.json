{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [
    "id",
    "products",
    "total",
    "discountedTotal",
    "userId",
    "totalProducts",
    "totalQuantity"
  ],
  "properties": {
    "id": { "type": "integer" },
    "userId": { "type": "integer" },
    "total": { "type": "number" },
    "discountedTotal": { "type": "number" },
    "totalProducts": { "type": "integer" },
    "totalQuantity": { "type": "integer" },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "price",
          "quantity",
          "total",
          "discountPercentage",
          "thumbnail"
        ],
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "price": { "type": "number" },
          "quantity": { "type": "integer" },
          "total": { "type": "number" },
          "discountPercentage": { "type": "number" },
          "discountedTotal": { "type": "number" },
          "discountedPrice": { "type": "number" },
          "thumbnail": { "type": "string" }
        }
      }
    }
  }
}
